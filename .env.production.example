# ====================================================================
#  Template .env untuk PRODUKSI (VPS labloan.my.id)
#  Salin ke .env di server, lalu:
#    php artisan key:generate
#  Jangan commit file .env asli (sudah di-ignore oleh .gitignore).
# ====================================================================

APP_NAME=LabLoans
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://labloan.my.id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Asia/Jakarta

# Catat hanya error di produksi
LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database (isi sesuai MySQL di VPS) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=labloan
DB_USERNAME=labloan_user
DB_PASSWORD=CHANGE_ME

# --- Sesi & keamanan cookie (wajib true karena pakai HTTPS) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Aplikasi ini tidak mengirim email; biarkan log saja kecuali nanti dibutuhkan
MAIL_MAILER=log
